generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── User & Auth ─────────────────────────────────────────────────

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          String         // "ADMIN", "TEACHER", or "STUDENT"
  created_at    DateTime       @default(now())
  student       Student?
  teacher       Teacher?
  notifications Notification[]

  @@map("users")
}

// ─── Student ─────────────────────────────────────────────────────

model Student {
  id              Int          @id @default(autoincrement())
  user_id         Int          @unique
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  enrollment_date DateTime
  attendances     Attendance[]
  payments        Payment[]
  enrollments     Enrollment[]

  @@map("students")
}

// ─── Teacher ─────────────────────────────────────────────────────

model Teacher {
  id       Int       @id @default(autoincrement())
  user_id  Int       @unique
  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  classes  Class[]
  payments Payment[]

  @@map("teachers")
}

// ─── Class ───────────────────────────────────────────────────────

model Class {
  id                    Int          @id @default(autoincrement())
  teacher_id            Int
  teacher               Teacher      @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  name                  String
  date                  DateTime?
  start_time            String?      // Stored as "HH:mm" string for SQLite compatibility
  number_of_days_a_week Int?
  attendances           Attendance[]
  payments              Payment[]
  enrollments           Enrollment[]

  @@index([teacher_id])
  @@map("classes")
}

// ─── Enrollment (Student ↔ Class junction) ───────────────────────

model Enrollment {
  id          Int      @id @default(autoincrement())
  student_id  Int
  student     Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  class_id    Int
  class       Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  enrolled_at DateTime @default(now())

  @@unique([student_id, class_id])
  @@index([student_id])
  @@index([class_id])
  @@map("enrollments")
}

// ─── Attendance ──────────────────────────────────────────────────

model Attendance {
  id         Int      @id @default(autoincrement())
  student_id Int
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  class_id   Int
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  date       DateTime
  status     String   // "PRESENT", "ABSENT", or "LATE"

  @@index([student_id])
  @@index([class_id])
  @@index([date])
  @@map("attendance")
}

// ─── Payment ─────────────────────────────────────────────────────

model Payment {
  id           Int       @id @default(autoincrement())
  student_id   Int
  student      Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  teacher_id   Int
  teacher      Teacher   @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  class_id     Int
  class        Class     @relation(fields: [class_id], references: [id], onDelete: Cascade)
  amount       Float
  status       String    // "PAID", "PENDING", or "OVERDUE"
  due_date     DateTime
  payment_date DateTime?

  @@index([student_id])
  @@index([teacher_id])
  @@index([class_id])
  @@index([status])
  @@map("payments")
}

// ─── Notification ────────────────────────────────────────────────

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       String   // "FEE_REMINDER", "CLASS_REMINDER", "SYSTEM", "GENERAL"
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([is_read])
  @@map("notifications")
}
